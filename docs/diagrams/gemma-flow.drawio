<mxfile host="app.diagrams.net" agent="Disha" version="24.0.0">
  <diagram name="Gemma Reasoning Flow" id="disha-gemma-flow">
    <mxGraphModel dx="1000" dy="760" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1180" pageHeight="760" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="How Gemma 4 drives each feature — Gemma does the reasoning &amp; language; the deterministic core does the exact math, retrieval and crypto" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=14;fontStyle=1;fontColor=#2A2140;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1100" height="30" as="geometry" />
        </mxCell>

        <!-- Column headers -->
        <mxCell id="h1" value="Gemma 4 reasons" style="text;html=1;align=center;fontSize=12;fontStyle=1;fontColor=#5B3FD0;" vertex="1" parent="1"><mxGeometry x="300" y="58" width="250" height="20" as="geometry" /></mxCell>
        <mxCell id="h2" value="Deterministic core computes" style="text;html=1;align=center;fontSize=12;fontStyle=1;fontColor=#5B3FD0;" vertex="1" parent="1"><mxGeometry x="580" y="58" width="260" height="20" as="geometry" /></mxCell>
        <mxCell id="h3" value="User sees" style="text;html=1;align=center;fontSize=12;fontStyle=1;fontColor=#5B3FD0;" vertex="1" parent="1"><mxGeometry x="880" y="58" width="250" height="20" as="geometry" /></mxCell>

        <!-- Input + Gemma hub -->
        <mxCell id="input" value="User input&#10;📝 text · 📷 photo · 📍 GPS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7F0FE;strokeColor=#2E7DF5;fontColor=#0B2545;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="86" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="hub" value="Gemma 4 E2B&#10;LiteRT-LM · on-device&#10;the ONLY LLM&#10;&#10;reasons · picks the tool&#10;writes প্রোজ (BN/EN)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7B5CF0;strokeColor=#5B3FD0;fontColor=#FFFFFF;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="170" width="180" height="360" as="geometry" />
        </mxCell>

        <!-- Row 1: Triage -->
        <mxCell id="g1" value="Read SOS text + photo → structured JSON&#10;{priority, signals, rationale}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEE9FC;strokeColor=#7B5CF0;fontColor=#2A2140;fontSize=11;" vertex="1" parent="1"><mxGeometry x="290" y="86" width="260" height="56" as="geometry" /></mxCell>
        <mxCell id="t1" value="Triage engine ranks the queue&#10;(rule-based fallback if model is off)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF7F0;strokeColor=#0E9D68;fontColor=#0B3D2A;fontSize=11;" vertex="1" parent="1"><mxGeometry x="580" y="86" width="270" height="56" as="geometry" /></mxCell>
        <mxCell id="r1" value="🚑 Prioritised queue + &#10;“needs human review” flag" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#D92D20;fontColor=#7A1B14;fontSize=11;" vertex="1" parent="1"><mxGeometry x="880" y="86" width="260" height="56" as="geometry" /></mxCell>

        <!-- Row 2: First Aid -->
        <mxCell id="g2" value="Detect language · translate BN→EN once for retrieval · write grounded answer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEE9FC;strokeColor=#7B5CF0;fontColor=#2A2140;fontSize=11;" vertex="1" parent="1"><mxGeometry x="290" y="170" width="260" height="56" as="geometry" /></mxCell>
        <mxCell id="t2" value="RAG retriever (k=4) over&#10;WHO / IFRC / Red Cross packs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF7F0;strokeColor=#0E9D68;fontColor=#0B3D2A;fontSize=11;" vertex="1" parent="1"><mxGeometry x="580" y="170" width="270" height="56" as="geometry" /></mxCell>
        <mxCell id="r2" value="🩹 Cited first-aid steps —&#10;only the sources actually used" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#D92D20;fontColor=#7A1B14;fontSize=11;" vertex="1" parent="1"><mxGeometry x="880" y="170" width="260" height="56" as="geometry" /></mxCell>

        <!-- Row 3: Shelter -->
        <mxCell id="g3" value="Select the GIS tool from the request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEE9FC;strokeColor=#7B5CF0;fontColor=#2A2140;fontSize=11;" vertex="1" parent="1"><mxGeometry x="290" y="254" width="260" height="56" as="geometry" /></mxCell>
        <mxCell id="t3" value="Dijkstra flood-avoid on OSM graph / nearest of 9,525 shelters" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF7F0;strokeColor=#0E9D68;fontColor=#0B3D2A;fontSize=11;" vertex="1" parent="1"><mxGeometry x="580" y="254" width="270" height="56" as="geometry" /></mxCell>
        <mxCell id="r3" value="🗺️ Walking route or&#10;safe-direction guidance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#D92D20;fontColor=#7A1B14;fontSize=11;" vertex="1" parent="1"><mxGeometry x="880" y="254" width="260" height="56" as="geometry" /></mxCell>

        <!-- Row 4: Summary -->
        <mxCell id="g4" value="Write the coordinator briefing from the real counts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEE9FC;strokeColor=#7B5CF0;fontColor=#2A2140;fontSize=11;" vertex="1" parent="1"><mxGeometry x="290" y="338" width="260" height="56" as="geometry" /></mxCell>
        <mxCell id="t4" value="SosRepository counts computed in code (verified reports only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF7F0;strokeColor=#0E9D68;fontColor=#0B3D2A;fontSize=11;" vertex="1" parent="1"><mxGeometry x="580" y="338" width="270" height="56" as="geometry" /></mxCell>
        <mxCell id="r4" value="📋 Briefing with&#10;never-invented numbers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#D92D20;fontColor=#7A1B14;fontSize=11;" vertex="1" parent="1"><mxGeometry x="880" y="338" width="260" height="56" as="geometry" /></mxCell>

        <!-- Row 5: Mesh -->
        <mxCell id="g5" value="(no model needed — pure transport &amp; crypto)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F2F2F2;strokeColor=#9AA0A6;fontColor=#444444;fontSize=11;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="290" y="422" width="260" height="56" as="geometry" /></mxCell>
        <mxCell id="t5" value="Ed25519 sign → Nearby Connections → verify-before-trust (scheme==ed25519)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF7F0;strokeColor=#0E9D68;fontColor=#0B3D2A;fontSize=11;" vertex="1" parent="1"><mxGeometry x="580" y="422" width="270" height="56" as="geometry" /></mxCell>
        <mxCell id="r5" value="📻 Trusted reports merged ·&#10;forgeries quarantined" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#D92D20;fontColor=#7A1B14;fontSize=11;" vertex="1" parent="1"><mxGeometry x="880" y="422" width="260" height="56" as="geometry" /></mxCell>

        <!-- Fallback lane -->
        <mxCell id="fallback" value="Fallback — Gemma unavailable (not downloaded / low-RAM device): the deterministic core still runs rule-based triage, shelter direction, mesh SOS and one-tap emergency calls. Maps &amp; mesh never depend on the model." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#F5822B;fontColor=#7A3E00;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="290" y="508" width="850" height="46" as="geometry" />
        </mxCell>

        <!-- Offline note -->
        <mxCell id="offline" value="Every arrow runs on the phone — no internet, no server, no cloud." style="text;html=1;align=center;fontSize=12;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="290" y="566" width="850" height="20" as="geometry" />
        </mxCell>

        <!-- Edges input->hub -->
        <mxCell id="ei" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#2E7DF5;strokeWidth=2;" edge="1" parent="1" source="input" target="hub"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- hub -> gemma-role -->
        <mxCell id="eg1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5B3FD0;" edge="1" parent="1" source="hub" target="g1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eg2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5B3FD0;" edge="1" parent="1" source="hub" target="g2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eg3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5B3FD0;" edge="1" parent="1" source="hub" target="g3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eg4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5B3FD0;" edge="1" parent="1" source="hub" target="g4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eg5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;dashed=1;strokeColor=#9AA0A6;" edge="1" parent="1" source="hub" target="g5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- gemma-role -> tool -->
        <mxCell id="et1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#0E9D68;" edge="1" parent="1" source="g1" target="t1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="et2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#0E9D68;" edge="1" parent="1" source="g2" target="t2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="et3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#0E9D68;" edge="1" parent="1" source="g3" target="t3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="et4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#0E9D68;" edge="1" parent="1" source="g4" target="t4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="et5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#0E9D68;" edge="1" parent="1" source="g5" target="t5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- tool -> result -->
        <mxCell id="er1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#D92D20;" edge="1" parent="1" source="t1" target="r1"><mxGeometry relative="1" as="geometry" /></mxCell>
