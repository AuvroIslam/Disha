<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive launcher icon: the whole tile is Disha green (edge-to-edge, no white padding the
     launcher would otherwise add around a legacy bitmap), with the owl mark as the foreground. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_green" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
